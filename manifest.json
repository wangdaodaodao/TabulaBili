{
  "manifest_version": 3,
  "name": "TabulaBili (初见哔哩)",
  "version": "1.0",
  "author": "wangdaodao",
  "description": "减少基于账号登录态和浏览历史的个性化推荐，让首页内容变得更泛化、更随机、更像公共热门流。",
  "permissions": [
    "declarativeNetRequestWithHostAccess",
    "activeTab"
  ],
  "host_permissions": [
    "*://api.bilibili.com/*"
  ],
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "TabulaBili 推荐设置",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "rules",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  }
}
